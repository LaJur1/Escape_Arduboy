{
    "configurations": [
        {
            "name": "Arduboy (SSD1309)",
            "includePath": [
                "${env:LOCALAPPDATA}/Arduino15/packages/arduboy-homemade/hardware/avr/1.4.0/cores/arduino",
                "${env:LOCALAPPDATA}/Arduino15/packages/arduboy-homemade/hardware/avr/1.4.0/variants/leonardo",
                "${env:LOCALAPPDATA}/Arduino15/packages/arduboy-homemade/hardware/avr/1.4.0/libraries/**",
                "${env:LOCALAPPDATA}/Arduino15/packages/arduino/tools/avr-gcc/7.3.0-atmel3.6.1-arduino5/avr/include",
                "${env:LOCALAPPDATA}/Arduino15/packages/arduino/tools/avr-gcc/7.3.0-atmel3.6.1-arduino5/lib/gcc/avr/7.3.0/include",
                "${workspaceFolder}"
            ],
            "defines": [
                "ARDUBOY_10",
                "OLED_SSD1309",
                "__AVR_ATmega32U4__",
                "F_CPU=16000000L",
                "ARDUINO=10819",
                "USB_VID=0x2341",
                "USB_PID=0x8036"
            ],
            "compilerPath": "${env:LOCALAPPDATA}/Arduino15/packages/arduino/tools/avr-gcc/7.3.0-atmel3.6.1-arduino5/bin/avr-g++.exe",
            "cStandard": "c11",
            "cppStandard": "c++11",
            "intelliSenseMode": "gcc-x86"
        }
    ],
    "version": 4
}
